<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>风险总览 - 金融市场风险监测数据研判分析软件</title>
  <link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--mac-title:#e8e6e3;--mac-title-inactive:#f6f6f6;--sidebar-bg:#1e1e2e;--sidebar-text:#a6adc8;--sidebar-active:rgba(137,180,250,.12);--sidebar-active-text:#89b4fa;--content-bg:#11111b;--content-bg-2:#181825;--card-bg:#1e1e2e;--card-border:rgba(255,255,255,.04);--text-primary:#cdd6f4;--text-secondary:#6c7086;--text-dim:#45475a;--accent-blue:#89b4fa;--accent-green:#a6e3a1;--accent-red:#f38ba8;--accent-yellow:#f9e2af;--accent-mauve:#cba6f7;--accent-peach:#fab387;--accent-teal:#94e2d5;--shadow-heavy:0 30px 80px rgba(0,0,0,.6),0 0 1px rgba(255,255,255,.05);--radius:10px}
    body{font-family:'Noto Sans SC',-apple-system,BlinkMacSystemFont,sans-serif;background:#0a0a12;display:flex;align-items:center;justify-content:center;min-height:100vh;overflow:hidden;color:var(--text-primary)}
    .desktop-bg{position:fixed;inset:0;background:linear-gradient(135deg,#0c0c1d 0%,#1a1a2e 40%,#16213e 70%,#0f3460 100%);z-index:0}
    .desktop-bg::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 20%,rgba(137,180,250,.04) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(203,166,247,.03) 0%,transparent 50%)}
    .mac-window{position:relative;z-index:1;width:1280px;max-width:96vw;height:820px;max-height:90vh;border-radius:12px;overflow:hidden;box-shadow:var(--shadow-heavy);display:flex;flex-direction:column;border:1px solid rgba(255,255,255,.06)}
    .title-bar{height:52px;min-height:52px;background:linear-gradient(180deg,#2a2a3c 0%,#232336 100%);display:flex;align-items:center;padding:0 16px;border-bottom:1px solid rgba(0,0,0,.4);-webkit-app-region:drag;position:relative}
    .traffic-lights{display:flex;gap:8px;z-index:2}
    .traffic-light{width:12px;height:12px;border-radius:50%;position:relative}
    .traffic-light.close{background:#ec6a5e;border:1px solid #d14f44}
    .traffic-light.minimize{background:#f4be4f;border:1px solid #d69e2e}
    .traffic-light.maximize{background:#61c554;border:1px solid #4da83f}
    .title-bar-text{position:absolute;left:50%;transform:translateX(-50%);font-size:13px;font-weight:500;color:#a0a0b8;letter-spacing:.3px;white-space:nowrap}
    .title-bar-right{margin-left:auto;display:flex;align-items:center;gap:12px}
    .user-badge{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.04);padding:4px 12px 4px 8px;border-radius:6px;font-size:12px;color:var(--text-secondary)}
    .user-avatar{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,var(--accent-blue),var(--accent-mauve));display:flex;align-items:center;justify-content:center;overflow:hidden;font-size:10px;color:#fff;font-weight:600}
    .user-avatar img{width:100%;height:100%;object-fit:cover;display:block}
    .main-body{flex:1;display:flex;overflow:hidden;background:var(--content-bg)}
    .sidebar{width:220px;min-width:220px;background:var(--sidebar-bg);border-right:1px solid rgba(255,255,255,.04);display:flex;flex-direction:column;padding:12px 0;overflow-y:auto}
    .sidebar-section{padding:0 12px;margin-bottom:4px}
    .sidebar-label{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);padding:12px 12px 6px}
    .sidebar-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--sidebar-text);transition:all .15s;position:relative;margin-bottom:1px}
    .sidebar-item:hover{background:rgba(255,255,255,.04);color:var(--text-primary)}
    .sidebar-item.active{background:var(--sidebar-active);color:var(--sidebar-active-text)}
    .sidebar-item .icon{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:13px;opacity:.7}
    .sidebar-item.active .icon{opacity:1}
    .sidebar-item .badge{margin-left:auto;background:var(--accent-red);color:#11111b;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;min-width:18px;text-align:center}
    .sidebar-divider{height:1px;background:rgba(255,255,255,.04);margin:8px 12px}
    .sidebar-status{margin-top:auto;padding:12px 16px;border-top:1px solid rgba(255,255,255,.04)}
    .status-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:6px}
    .status-dot.online{background:var(--accent-green);box-shadow:0 0 6px rgba(166,227,161,.4)}
    .status-text{font-size:11px;color:var(--text-secondary)}
    .content{flex:1;display:flex;flex-direction:column;overflow:hidden}
    .content-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid rgba(255,255,255,.03);background:var(--content-bg-2)}
    .content-title{font-size:18px;font-weight:600;color:var(--text-primary);letter-spacing:-.2px}
    .content-subtitle{font-size:12px;color:var(--text-secondary);margin-top:2px}
    .header-actions{display:flex;align-items:center;gap:8px}
    .btn{padding:6px 14px;border-radius:6px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);color:var(--text-secondary);font-size:12px;cursor:pointer;transition:all .15s;font-family:inherit}
    .btn:hover{background:rgba(255,255,255,.08);color:var(--text-primary)}
    .btn.primary{background:rgba(137,180,250,.15);border-color:rgba(137,180,250,.2);color:var(--accent-blue)}
    .btn.primary:hover{background:rgba(137,180,250,.25)}
    .time-display{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-dim)}
    .content-scroll{flex:1;overflow-y:auto;padding:20px 24px}
    .content-scroll::-webkit-scrollbar{width:6px}
    .content-scroll::-webkit-scrollbar-track{background:transparent}
    .content-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:3px}
    .kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
    .kpi-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:8px;padding:16px 18px}
    .kpi-label{font-size:11px;color:var(--text-secondary);margin-bottom:8px;letter-spacing:.3px}
    .kpi-value{font-family:'JetBrains Mono',monospace;font-size:26px;font-weight:600;letter-spacing:-1px}
    .kpi-sub{display:flex;align-items:center;gap:6px;margin-top:6px;font-size:11px}
    .kpi-change{font-family:'JetBrains Mono',monospace;font-weight:500}
    .kpi-change.up{color:var(--accent-red)}
    .kpi-change.down{color:var(--accent-green)}
    .kpi-change.neutral{color:var(--accent-yellow)}
    .kpi-desc{color:var(--text-dim)}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
    .grid-3-1{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:20px}
    .card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:8px;padding:18px;overflow:hidden}
    .card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .card-title{font-size:13px;font-weight:600;color:var(--text-primary)}
    .card-tag{font-size:10px;padding:2px 8px;border-radius:4px;font-weight:500}
    .tag-warn{background:rgba(243,139,168,.12);color:var(--accent-red)}
    .tag-safe{background:rgba(166,227,161,.12);color:var(--accent-green)}
    .tag-info{background:rgba(137,180,250,.12);color:var(--accent-blue)}
    .chart-area{width:100%}
    .chart-area svg{width:100%;display:block}
    .data-table{width:100%;border-collapse:collapse;font-size:12px}
    .data-table th{text-align:left;padding:8px 10px;color:var(--text-dim);font-weight:500;font-size:11px;letter-spacing:.3px;border-bottom:1px solid rgba(255,255,255,.04)}
    .data-table td{padding:10px 10px;color:var(--text-secondary);border-bottom:1px solid rgba(255,255,255,.02);font-family:'JetBrains Mono',monospace;font-size:11px}
    .data-table tr:hover td{background:rgba(255,255,255,.015)}
    .data-table .name-col{font-family:'Noto Sans SC',sans-serif;color:var(--text-primary);font-weight:500}
    .risk-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600}
    .risk-high{background:rgba(243,139,168,.15);color:var(--accent-red)}
    .risk-mid{background:rgba(249,226,175,.15);color:var(--accent-yellow)}
    .risk-low{background:rgba(166,227,161,.12);color:var(--accent-green)}
    .alert-list{display:flex;flex-direction:column;gap:8px}
    .alert-item{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:6px;background:rgba(255,255,255,.015);border-left:3px solid transparent}
    .alert-item.alert-red{border-left-color:var(--accent-red)}
    .alert-item.alert-yellow{border-left-color:var(--accent-yellow)}
    .alert-item.alert-blue{border-left-color:var(--accent-blue)}
    .alert-time{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text-dim);white-space:nowrap;margin-top:2px}
    .alert-body{font-size:12px;color:var(--text-secondary);line-height:1.5}
    .alert-body strong{color:var(--text-primary);font-weight:500}
    .bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .bar-label{font-size:11px;color:var(--text-secondary);width:70px;text-align:right;flex-shrink:0}
    .bar-track{flex:1;height:8px;background:rgba(255,255,255,.04);border-radius:4px;overflow:hidden}
    .bar-fill{height:100%;border-radius:4px;transition:width 1s ease}
    .bar-val{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-dim);width:40px;flex-shrink:0}
    @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .kpi-card,.card,.alert-item{animation:fadeIn .4s ease both}
    .kpi-card:nth-child(2),.card:nth-child(2){animation-delay:.05s}
    .kpi-card:nth-child(3){animation-delay:.1s}
    .kpi-card:nth-child(4){animation-delay:.15s}
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:1000;animation:fadeIn .2s ease}
    .modal-content{background:var(--card-bg);border:1px solid var(--card-border);border-radius:12px;width:400px;max-width:90vw;overflow:hidden}
    .modal-header{display:flex;align-items:center;justify-content:center;padding:16px 20px;background:var(--content-bg-2);border-bottom:1px solid rgba(255,255,255,.05);position:relative}
    .modal-header .traffic-lights{display:flex;gap:8px;position:absolute;left:20px;top:50%;transform:translateY(-50%)}
    .modal-header .traffic-light{width:12px;height:12px;border-radius:50%;cursor:pointer}
    .modal-header .traffic-light.close{background:#ff5f57}
    .modal-header .traffic-light.minimize{background:#febc2e}
    .modal-header .traffic-light.maximize{background:#28c840}
    .modal-title{font-size:14px;font-weight:600;color:var(--text-primary)}
    .modal-body{padding:24px 20px}
    .modal-body p{font-size:13px;color:var(--text-secondary);margin-bottom:16px}
    .report-progress{height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden;margin-bottom:12px}
    .progress-fill{height:100%;background:var(--accent-blue);border-radius:3px;width:0;transition:width .4s ease}
    .report-status{font-size:11px;color:var(--text-dim)}
    .report-success{text-align:center;padding:20px 0}
    .success-icon{display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;background:rgba(166,227,161,.15);color:var(--accent-green);border-radius:50%;font-size:24px;margin-bottom:16px}
    .report-filename{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-dim);margin:8px 0 20px}
    .toast-notification{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(100px);background:var(--card-bg);border:1px solid var(--card-border);border-radius:8px;padding:12px 20px;font-size:13px;color:var(--text-primary);z-index:1001;transition:transform .3s ease;display:flex;align-items:center;gap:10px}
    .toast-notification.show{transform:translateX(-50%) translateY(0)}
    .toast-notification.success{border-left:3px solid var(--accent-green)}
    .toast-notification.warning{border-left:3px solid var(--accent-yellow)}
    .toast-notification.error{border-left:3px solid var(--accent-red)}
    .refresh-toggle{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text-dim);cursor:pointer;padding:4px 8px;border-radius:4px;transition:all .15s}
    .refresh-toggle:hover{background:rgba(255,255,255,.04);color:var(--text-secondary)}
    .refresh-toggle.active{color:var(--accent-green)}
    .refresh-toggle .dot{width:6px;height:6px;border-radius:50%;background:currentColor}
    .refresh-toggle.active .dot{animation:pulse 1.5s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
    .alert-item{cursor:pointer;transition:all .15s}
    .alert-item:hover{background:rgba(255,255,255,.04);transform:translateX(2px)}
    .bar-fill{cursor:pointer}
    .bar-fill:hover{filter:brightness(1.2)}
    .institution-row{cursor:pointer;transition:background .15s}
    .institution-row:hover td{background:rgba(137,180,250,.08)!important}
    .kpi-card{cursor:pointer}
    .kpi-card:hover{border-color:rgba(137,180,250,.2)}
    .detail-modal .detail-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
    .detail-modal .detail-row:last-child{border-bottom:none}
    .detail-modal .detail-label{color:var(--text-secondary);font-size:12px}
    .detail-modal .detail-value{color:var(--text-primary);font-family:'JetBrains Mono',monospace;font-size:12px}
    .risk-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:12px;cursor:pointer;padding:8px;border-radius:6px;transition:background .15s}
    .risk-bar-row:hover{background:rgba(255,255,255,.04)}
    .risk-bar-label{flex:0 0 70px;font-size:11px;color:var(--text-secondary);text-align:right}
    .risk-bar-track{flex:1;height:10px;background:rgba(255,255,255,.04);border-radius:5px;overflow:hidden;position:relative}
    .risk-bar-fill{height:100%;border-radius:5px;transition:width 1s ease}
    .risk-bar-value{flex:0 0 40px;font-family:'JetBrains Mono';font-size:11px;color:var(--text-dim);text-align:right}
    .risk-detail-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03)}
    .trend-btn{padding:4px 10px;font-size:10px;border-radius:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);color:var(--text-secondary);cursor:pointer;transition:all .15s}
    .trend-btn:hover{background:rgba(255,255,255,.08)}
    .trend-btn.active{background:rgba(137,180,250,.15);border-color:rgba(137,180,250,.2);color:var(--accent-blue)}
  </style>
</head>
<body>
  <div class="desktop-bg"></div>
  <div class="mac-window">
    <div class="title-bar">
      <div class="traffic-lights">
        <div class="traffic-light close"></div>
        <div class="traffic-light minimize"></div>
        <div class="traffic-light maximize"></div>
      </div>
      <div class="title-bar-text">金融市场风险监测数据研判分析软件</div>
      <div class="title-bar-right">
        <div class="time-display" id="clock"></div>
        <div class="user-badge">
          <div class="user-avatar">鲍</div>
          <span>鲍姝帆</span>
        </div>
      </div>
    </div>
    <div class="main-body">
      <div class="sidebar">
        <div class="sidebar-section">
          <div class="sidebar-label">软件功能</div>
          <div class="sidebar-item active">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span>
            风险总览
          </div>
          <div class="sidebar-item" onclick="location.href='market.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
            市场监测
          </div>
          <div class="sidebar-item" onclick="location.href='credit.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            信用风险
            <span class="badge">3</span>
          </div>
          <div class="sidebar-item" onclick="location.href='liquidity.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg></span>
            流动性分析
          </div>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-item" onclick="location.href='stress.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>
            压力测试
          </div>
          <div class="sidebar-item" onclick="location.href='var.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg></span>
            VaR模型
          </div>
          <div class="sidebar-item" onclick="location.href='correlation.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
            关联分析
          </div>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-item" onclick="location.href='system.html'">
            <span class="icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
            系统设置
          </div>
        </div>
        <div class="sidebar-status">
          <span class="status-dot online"></span>
          <span class="status-text">数据源连接正常 · 延迟 12ms</span>
        </div>
      </div>
      <div class="content">
        <div class="content-header">
          <div>
            <div class="content-title">风险总览</div>
            <div class="content-subtitle">全市场风险指标实时监测 · 数据更新于 <span id="updateTime"></span></div>
          </div>
          <div class="header-actions">
            <button class="btn" onclick="showDashboardConfig()">仪表盘配置</button>
            <button class="btn" onclick="showAlertHistory()">预警历史</button>
            <button class="btn" onclick="showRiskDistribution()">风险分布</button>
            <button class="btn" onclick="compareRiskPeriods()">对比分析</button>
            <div class="refresh-toggle active" id="refreshToggle" onclick="toggleAutoRefresh()">
              <span class="dot"></span>
              <span id="refreshText">实时刷新</span>
            </div>
            <button class="btn" onclick="exportData()">导出数据</button>
            <button class="btn primary" onclick="generateReport()">生成报告</button>
          </div>
        </div>
        <div class="content-scroll">
          <div class="kpi-row">
            <div class="kpi-card" onclick="showKpiDetail('综合风险指数','67.4','综合风险指数是衡量金融市场整体风险水平的宏观指标，基于利率风险、信用风险、汇率风险、流动性风险、操作风险、合规风险六类风险因子加权计算得出。指数范围0-100，数值越高表示风险越大。')">
              <div class="kpi-label">综合风险指数 <span style="color:var(--accent-blue);cursor:help;">ⓘ</span></div>
              <div class="kpi-value" style="color:var(--accent-yellow)">67.4</div>
              <div class="kpi-sub"><span class="kpi-change up">+3.2</span><span class="kpi-desc">较上日</span></div>
            </div>
            <div class="kpi-card" onclick="showKpiDetail('监测预警数量','18','监测预警数量统计近24小时内触发的各类风险预警事件，分为红色(严重)、橙色(较高)、黄色(关注)三个等级。当风险指标超过设定阈值时自动触发预警。')">
              <div class="kpi-label">监测预警数量 <span style="color:var(--accent-blue);cursor:help;">ⓘ</span></div>
              <div class="kpi-value" style="color:var(--accent-red)">18</div>
              <div class="kpi-sub"><span class="kpi-change up">+5</span><span class="kpi-desc">红色预警 3 · 橙色 7 · 黄色 8</span></div>
            </div>
            <div class="kpi-card" onclick="showKpiDetail('VaR(99%,1D)','2.34%','VaR(Value at Risk)在99%置信水平下，1天内最大可能损失。表示在未来1天内，有99%的把握认为损失不会超过2.34%。回溯检验显示近250日有4次突破。')">
              <div class="kpi-label">VaR(99%, 1D) <span style="color:var(--accent-blue);cursor:help;">ⓘ</span></div>
              <div class="kpi-value" style="color:var(--accent-mauve)">2.34%</div>
              <div class="kpi-sub"><span class="kpi-change up">+0.18%</span><span class="kpi-desc">历史分位 P87</span></div>
            </div>
            <div class="kpi-card" onclick="showKpiDetail('市场波动率(VIX)','24.8','VIX指数反映市场对未来30天波动率的预期。低于15为低位(风险偏好)，15-25为正常区间，25-35为偏高(谨慎)，高于35为高位(恐慌)。当前24.8表示市场情绪偏谨慎。')">
              <div class="kpi-label">市场波动率(VIX) <span style="color:var(--accent-blue);cursor:help;">ⓘ</span></div>
              <div class="kpi-value" style="color:var(--accent-peach)">24.8</div>
              <div class="kpi-sub"><span class="kpi-change neutral">+0.3</span><span class="kpi-desc">中等偏高</span></div>
            </div>
          </div>
          <div class="grid-3-1">
            <div class="card">
              <div class="card-head"><span class="card-title">综合风险指数趋势</span>
                <div style="display:flex;gap:6px;align-items:center;">
                  <button class="trend-btn active" onclick="switchTrendPeriod(this,'30d')">30日</button>
                  <button class="trend-btn" onclick="switchTrendPeriod(this,'90d')">90日</button>
                  <button class="trend-btn" onclick="switchTrendPeriod(this,'1y')">1年</button>
                </div>
              </div>
              <span class="card-tag tag-warn" id="riskStatusTag">关注</span>
              <div class="chart-area" id="riskTrendChart"></div>
            </div>
            <div class="card">
              <div class="card-head"><span class="card-title">风险等级分布</span><span class="card-tag tag-info">实时</span></div>
              <div style="padding:6px 0;">
                <div class="risk-bar-row" onclick="showRiskFactorDetail('利率风险',78,'高','国债收益率曲线倒挂','+18bp')">
                  <span class="risk-bar-label">利率风险</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:78%;background:var(--accent-red)"></div></div>
                  <span class="risk-bar-value">78</span>
                </div>
                <div class="risk-bar-row" onclick="showRiskFactorDetail('信用风险',65,'中高','AA级企业债利差走阔','+22bp')">
                  <span class="risk-bar-label">信用风险</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:65%;background:var(--accent-peach)"></div></div>
                  <span class="risk-bar-value">65</span>
                </div>
                <div class="risk-bar-row" onclick="showRiskFactorDetail('汇率风险',52,'中','人民币波动率上升','6.8%')">
                  <span class="risk-bar-label">汇率风险</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:52%;background:var(--accent-yellow)"></div></div>
                  <span class="risk-bar-value">52</span>
                </div>
                <div class="risk-bar-row" onclick="showRiskFactorDetail('流动性风险',41,'中低','SHIBOR隔夜上行','+15bp')">
                  <span class="risk-bar-label">流动性</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:41%;background:var(--accent-blue)"></div></div>
                  <span class="risk-bar-value">41</span>
                </div>
                <div class="risk-bar-row" onclick="showRiskFactorDetail('操作风险',28,'低','系统运行正常','无异常')">
                  <span class="risk-bar-label">操作风险</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:28%;background:var(--accent-green)"></div></div>
                  <span class="risk-bar-value">28</span>
                </div>
                <div class="risk-bar-row" onclick="showRiskFactorDetail('合规风险',33,'低','无重大违规','监管评分A')">
                  <span class="risk-bar-label">合规风险</span>
                  <div class="risk-bar-track"><div class="risk-bar-fill" style="width:33%;background:var(--accent-teal)"></div></div>
                  <span class="risk-bar-value">33</span>
                </div>
              </div>
            </div>
          </div>
          <div class="grid-2">
            <div class="card">
              <div class="card-head"><span class="card-title">实时预警信息</span>
                <div style="display:flex;gap:6px;align-items:center;">
                  <button class="trend-btn" onclick="filterAlerts('all')">全部</button>
                  <button class="trend-btn" onclick="filterAlerts('red')">红色</button>
                  <button class="trend-btn" onclick="filterAlerts('orange')">橙色</button>
                  <button class="trend-btn" onclick="acknowledgeAllAlerts()">全部确认</button>
                </div>
              </div>
              <div class="alert-list" id="alertListContainer">
                <div class="alert-item alert-red" onclick="showAlertDetail('国债收益率曲线倒挂','红色','09:32','10Y-2Y利差降至-18bp，触发阈值预警。当前利差为近三年最低值，反映市场对经济衰退预期升温。','78.5','持续恶化中')"><span class="alert-time">09:32</span><div class="alert-body"><strong>[红色]</strong> 国债收益率曲线倒挂加深，10Y-2Y利差降至-18bp，触发阈值预警</div><button class="trend-btn" onclick="event.stopPropagation();acknowledgeAlert(this)" style="margin-left:auto;padding:2px 6px;font-size:9px;">确认</button></div>
                <div class="alert-item alert-red" onclick="showAlertDetail('信用债利差走阔','红色','09:15','AA级企业债违约概率升至3.7%，单日走阔22bp。','65.2','需关注')"><span class="alert-time">09:15</span><div class="alert-body"><strong>[红色]</strong> 信用债利差单日走阔22bp，AA级企业债违约概率模型输出升至3.7%</div><button class="trend-btn" onclick="event.stopPropagation();acknowledgeAlert(this)" style="margin-left:auto;padding:2px 6px;font-size:9px;">确认</button></div>
                <div class="alert-item alert-yellow" onclick="showAlertDetail('人民币汇率波动','橙色','08:58','离岸人民币隐含波动率达6.8%，突破近三月高位。','52.3','波动加剧')"><span class="alert-time">08:58</span><div class="alert-body"><strong>[橙色]</strong> 离岸人民币汇率波动率突破近三月高位，隐含波动率达6.8%</div><button class="trend-btn" onclick="event.stopPropagation();acknowledgeAlert(this)" style="margin-left:auto;padding:2px 6px;font-size:9px;">确认</button></div>
                <div class="alert-item alert-yellow" onclick="showAlertDetail('资金面趋紧','橙色','08:41','SHIBOR隔夜上行15bp至2.35%，银行间流动性收紧。','41.8','边际恶化')"><span class="alert-time">08:41</span><div class="alert-body"><strong>[橙色]</strong> 银行间同业拆借利率SHIBOR隔夜上行15bp至2.35%，资金面趋紧</div><button class="trend-btn" onclick="event.stopPropagation();acknowledgeAlert(this)" style="margin-left:auto;padding:2px 6px;font-size:9px;">确认</button></div>
                <div class="alert-item alert-blue" onclick="showAlertDetail('期权波动率异常','蓝色','08:30','Put-Call比升至1.42，沪深300期权隐含波动率偏度指数异常。','35.2','需观察')"><span class="alert-time">08:30</span><div class="alert-body"><strong>[蓝色]</strong> 沪深300期权隐含波动率偏度指数异常，Put-Call比升至1.42</div><button class="trend-btn" onclick="event.stopPropagation();acknowledgeAlert(this)" style="margin-left:auto;padding:2px 6px;font-size:9px;">确认</button></div>
              </div>
            </div>
            <div class="card">
              <div class="card-head"><span class="card-title">重点监测机构</span>
                <div style="display:flex;gap:6px;align-items:center;">
                  <button class="trend-btn" onclick="sortInstitutions('score')">按评分</button>
                  <button class="trend-btn" onclick="sortInstitutions('name')">按名称</button>
                  <button class="trend-btn" onclick="addToWatchlist()">添加关注</button>
                  <button class="trend-btn" onclick="exportInstitutionList()">导出清单</button>
                </div>
              </div>
              <table class="data-table">
                <thead><tr><th onclick="sortInstitutions('name')">机构名称 ↕</th><th onclick="sortInstitutions('score')">风险评分 ↕</th><th>等级</th><th>操作</th></tr></thead>
                <tbody id="institutionTableBody">
                  <tr class="institution-row" onclick="showInstitutionDetail('恒泰信托','82.1','高','信托','178亿','3.7%')"><td class="name-col">恒泰信托</td><td>82.1</td><td><span class="risk-badge risk-high">高</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('恒泰信托')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('鑫融资管','76.5','高','资管','145亿','2.9%')"><td class="name-col">鑫融资管</td><td>76.5</td><td><span class="risk-badge risk-high">高</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('鑫融资管')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('中汇租赁','71.3','高','租赁','112亿','2.6%')"><td class="name-col">中汇租赁</td><td>71.3</td><td><span class="risk-badge risk-high">高</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('中汇租赁')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('东海期货','58.9','中','期货','89亿','1.8%')"><td class="name-col">东海期货</td><td>58.9</td><td><span class="risk-badge risk-mid">中</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('东海期货')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('华信基金','54.2','中','基金','67亿','1.5%')"><td class="name-col">华信基金</td><td>54.2</td><td><span class="risk-badge risk-mid">中</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('华信基金')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('银通资本','47.6','中','证券','45亿','1.2%')"><td class="name-col">银通资本</td><td>47.6</td><td><span class="risk-badge risk-mid">中</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('银通资本')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('国盛证券','32.4','低','证券','23亿','0.8%')"><td class="name-col">国盛证券</td><td>32.4</td><td><span class="risk-badge risk-low">低</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('国盛证券')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                  <tr class="institution-row" onclick="showInstitutionDetail('瑞银信投','28.7','低','投资','18亿','0.6%')"><td class="name-col">瑞银信投</td><td>28.7</td><td><span class="risk-badge risk-low">低</span></td><td><button class="trend-btn" onclick="event.stopPropagation();removeInstitution('瑞银信投')" style="padding:2px 6px;font-size:9px;">移除</button></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    function updateClock(){
      const now=new Date();
      const h=String(now.getHours()).padStart(2,'0');
      const m=String(now.getMinutes()).padStart(2,'0');
      const s=String(now.getSeconds()).padStart(2,'0');
      document.getElementById('clock').textContent=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')} ${h}:${m}:${s}`;
      document.getElementById('updateTime').textContent=`${h}:${m}`;
    }
    updateClock();
    setInterval(updateClock,1000);

    let autoRefreshEnabled=true;
    let refreshInterval;
    function toggleAutoRefresh(){
      autoRefreshEnabled=!autoRefreshEnabled;
      const toggle=document.getElementById('refreshToggle');
      const text=document.getElementById('refreshText');
      if(autoRefreshEnabled){
        toggle.classList.add('active');
        text.textContent='实时刷新';
        startAutoRefresh();
        showToast('已开启实时刷新','success');
      }else{
        toggle.classList.remove('active');
        text.textContent='已暂停';
        clearInterval(refreshInterval);
        showToast('已暂停实时刷新','warning');
      }
    }
    function startAutoRefresh(){
      clearInterval(refreshInterval);
      refreshInterval=setInterval(()=>{
        if(!autoRefreshEnabled)return;
        const kpiValues=document.querySelectorAll('.kpi-value');
        const kpiChanges=document.querySelectorAll('.kpi-change');
        kpiValues.forEach((v,i)=>{
          const baseValues=[67.4,18,2.34,24.8];
          const change=(Math.random()-0.5)*0.6;
          const newVal=(baseValues[i]+change).toFixed(i===2?2:i===3?1:1);
          v.textContent=newVal;
        });
        kpiChanges.forEach((c,i)=>{
          const change=(Math.random()-0.3)*2;
          c.textContent=(change>=0?'+':'')+change.toFixed(1);
          c.className='kpi-change '+(change>0.5?'up':change<-0.5?'down':'neutral');
        });
      },5000);
    }
    startAutoRefresh();

    function showAlertDetail(title,level,time,desc,value,trend){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">预警详情</span></div><div class="modal-body detail-modal"><p style="color:var(--text-primary);font-size:14px;margin-bottom:12px">${title}</p><div class="detail-row"><span class="detail-label">预警级别</span><span class="detail-value" style="color:${level==='红色'?'var(--accent-red)':level==='橙色'?'var(--accent-yellow)':'var(--accent-blue)'}">${level}</span></div><div class="detail-row"><span class="detail-label">触发时间</span><span class="detail-value">${time}</span></div><div class="detail-row"><span class="detail-label">风险值</span><span class="detail-value">${value}</span></div><div class="detail-row"><span class="detail-label">当前趋势</span><span class="detail-value">${trend}</span></div><div class="detail-row"><span class="detail-label">详细描述</span><span class="detail-value" style="color:var(--text-secondary)">${desc}</span></div><button class="btn primary" style="width:100%;margin-top:16px" onclick="this.closest('.modal-overlay').remove()">确定</button></div></div>`;
      document.body.appendChild(modal);
    }

    function showInstitutionDetail(name,score,level,type,exposure,defaultProb){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">机构详情</span></div><div class="modal-body detail-modal"><p style="color:var(--text-primary);font-size:14px;margin-bottom:12px">${name}</p><div class="detail-row"><span class="detail-label">机构类型</span><span class="detail-value">${type}</span></div><div class="detail-row"><span class="detail-label">风险评分</span><span class="detail-value" style="color:${level==='高'?'var(--accent-red)':level==='中'?'var(--accent-yellow)':'var(--accent-green)'}">${score}</span></div><div class="detail-row"><span class="detail-label">风险等级</span><span class="detail-value">${level}</span></div><div class="detail-row"><span class="detail-label">风险敞口</span><span class="detail-value">${exposure}</span></div><div class="detail-row"><span class="detail-label">违约概率</span><span class="detail-value">${defaultProb}</span></div><div class="detail-row"><span class="detail-label">建议措施</span><span class="detail-value" style="color:var(--accent-yellow)">${level==='高'?'立即压降敞口':level==='中'?'加强监控':'常规关注'}</span></div><div style="margin-top:16px;display:flex;gap:10px;"><button class="btn" onclick="showInstitutionHistory('${name}')" style="flex:1">查看历史</button><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="flex:1">确定</button></div></div></div>`;
      document.body.appendChild(modal);
    }

    function showRiskFactorDetail(name,value,level,reason,indicator){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      const levelColor=level==='高'?'var(--accent-red)':level==='中高'?'var(--accent-peach)':level==='中'?'var(--accent-yellow)':level==='中低'?'var(--accent-blue)':'var(--accent-green)';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">${name}详情</span></div><div class="modal-body detail-modal"><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;"><div style="text-align:center;padding:12px;background:rgba(255,255,255,.03);border-radius:8px;"><div style="font-size:11px;color:var(--text-secondary)">风险指数</div><div style="font-size:28px;font-family:'JetBrains Mono';color:${levelColor};font-weight:600">${value}</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px">${level}风险</div></div><div style="text-align:center;padding:12px;background:rgba(255,255,255,.03);border-radius:8px;"><div style="font-size:11px;color:var(--text-secondary)">关键指标</div><div style="font-size:22px;font-family:'JetBrains Mono';color:var(--text-primary)">${indicator}</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px">日变化</div></div></div><div class="detail-row"><span class="detail-label">风险等级</span><span class="detail-value" style="color:${levelColor}">${level}</span></div><div class="detail-row"><span class="detail-label">主要驱动因素</span><span class="detail-value">${reason}</span></div><div class="detail-row"><span class="detail-label">建议措施</span><span class="detail-value" style="color:var(--accent-yellow)">${value>=70?'需重点关注':value>=50?'保持监控':'常规跟踪'}</span></div><div style="margin-top:16px;display:flex;gap:10px;"><button class="btn" onclick="showRiskTrend('${name}')" style="flex:1">查看趋势</button><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="flex:1">确定</button></div></div></div>`;
      document.body.appendChild(modal);
    }

    function showInstitutionHistory(name){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">${name} - 历史风险评分</span></div><div class="modal-body" style="padding:20px"><p style="font-size:12px;color:var(--text-secondary);margin-bottom:12px;">近6个月风险评分变化趋势</p><div style="background:rgba(255,255,255,.03);border-radius:8px;padding:16px;"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><span style="font-size:11px;color:var(--text-dim)">2024/09</span><span style="font-family:'JetBrains Mono';color:var(--text-secondary)">68.2</span></div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><span style="font-size:11px;color:var(--text-dim)">2024/10</span><span style="font-family:'JetBrains Mono';color:var(--text-secondary)">72.5</span></div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><span style="font-size:11px;color:var(--text-dim)">2024/11</span><span style="font-family:'JetBrains Mono';color:var(--text-secondary)">75.8</span></div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><span style="font-size:11px;color:var(--text-dim)">2024/12</span><span style="font-family:'JetBrains Mono';color:var(--accent-yellow)">78.3</span></div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><span style="font-size:11px;color:var(--text-dim)">2025/01</span><span style="font-family:'JetBrains Mono';color:var(--accent-red)">80.1</span></div><div style="display:flex;align-items:center;justify-content:space-between;"><span style="font-size:11px;color:var(--text-primary)">2025/02</span><span style="font-family:'JetBrains Mono';color:var(--accent-red)">82.1</span></div></div><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;margin-top:16px;">确定</button></div></div>`;
      document.body.appendChild(modal);
    }

    function showRiskTrend(name){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">${name} - 趋势分析</span></div><div class="modal-body" style="padding:20px"><p style="font-size:13px;color:var(--text-secondary);margin-bottom:16px;">该风险因子近30日呈<span style="color:var(--accent-red)">上升趋势</span>，需持续关注。</p><div style="background:rgba(255,255,255,.03);border-radius:8px;padding:16px;margin-bottom:12px;"><div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="font-size:12px;color:var(--text-secondary)">30日均值</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">62.3</span></div><div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="font-size:12px;color:var(--text-secondary)">较上月</span><span style="font-family:'JetBrains Mono';color:var(--accent-red)">+8.5</span></div><div style="display:flex;justify-content:space-between;"><span style="font-size:12px;color:var(--text-secondary)">历史分位</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">P78</span></div></div><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;">确定</button></div></div>`;
      document.body.appendChild(modal);
    }

    function showKpiDetail(name,value,description){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">指标说明</span></div><div class="modal-body" style="padding:20px"><div style="text-align:center;margin-bottom:16px;"><div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px;">${name}</div><div style="font-size:28px;font-family:'JetBrains Mono';color:var(--accent-blue);font-weight:600">${value}</div></div><div style="background:rgba(255,255,255,.03);border-radius:8px;padding:16px;"><p style="font-size:13px;color:var(--text-secondary);line-height:1.7;">${description}</p></div><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;margin-top:16px;">确定</button></div></div>`;
      document.body.appendChild(modal);
    }

    function switchTrendPeriod(el,period){
      el.closest('.card-head').querySelectorAll('.trend-btn').forEach(b=>b.classList.remove('active'));
      el.classList.add('active');
      showToast('已切换至近'+{30d:'30日',90d:'90日',1y:'1年'}[period]+'趋势','success');
    }

    (function(){
      const data=[58,56,54,57,59,61,58,55,57,60,62,64,61,59,62,65,63,60,58,61,63,66,64,62,65,67,64,66,68,67.4];
      const w=580,h=120,pad=30;
      const minV=Math.min(...data)-3,maxV=Math.max(...data)+3;
      const sx=i=>(i/(data.length-1))*(w-pad*2)+pad;
      const sy=v=>h-pad-((v-minV)/(maxV-minV))*(h-pad*2);
      let path='M';
      data.forEach((v,i)=>{path+=(i?'L':'')+sx(i).toFixed(1)+','+sy(v).toFixed(1);});
      let area=path+'L'+sx(data.length-1)+','+h+'L'+sx(0)+','+h+'Z';
      const tY=sy(65);
      let svg=`<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="trendGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(249,226,175,0.25)"/><stop offset="100%" stop-color="rgba(249,226,175,0)"/></linearGradient></defs><line x1="${pad}" y1="${tY}" x2="${w-pad}" y2="${tY}" stroke="rgba(243,139,168,0.3)" stroke-dasharray="4,4"/><text x="${w-pad+4}" y="${tY+4}" fill="rgba(243,139,168,0.5)" font-size="9" font-family="JetBrains Mono">65</text><path d="${area}" fill="url(#trendGrad)"/><path d="${path}" fill="none" stroke="#f9e2af" stroke-width="2"/><circle cx="${sx(data.length-1)}" cy="${sy(data[data.length-1])}" r="4" fill="#f9e2af" stroke="#1e1e2e" stroke-width="2"/><text x="${sx(data.length-1)+8}" y="${sy(data[data.length-1])+4}" fill="#f9e2af" font-size="11" font-family="JetBrains Mono" font-weight="600">67.4</text><text x="${pad}" y="${h-6}" fill="rgba(108,112,134,0.6)" font-size="9" font-family="JetBrains Mono">02/23</text><text x="${sx(14)}" y="${h-6}" fill="rgba(108,112,134,0.6)" font-size="9" font-family="JetBrains Mono">03/09</text><text x="${w-pad-30}" y="${h-6}" fill="rgba(108,112,134,0.6)" font-size="9" font-family="JetBrains Mono">03/24</text></svg>`;
      document.getElementById('riskTrendChart').innerHTML=svg;
    })();

    function exportData(){
      const tables=document.querySelectorAll('.data-table');
      if(tables.length===0){showToast('当前页面暂无数据可导出','warning');return;}
      let csv='\uFEFF';
      tables.forEach((table,idx)=>{
        if(idx>0)csv+='\n\n';
        table.querySelectorAll('tr').forEach(row=>{
          const cells=row.querySelectorAll('th,td');
          const rowData=[];
          cells.forEach(cell=>{rowData.push('"'+cell.textContent.trim().replace(/"/g,'""')+'"');});
          csv+=rowData.join(',')+'\n';
        });
      });
      const now=new Date();
      const filename='dashboard_'+now.getFullYear()+String(now.getMonth()+1).padStart(2,'0')+String(now.getDate()).padStart(2,'0')+'.csv';
      const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
      const link=document.createElement('a');link.href=URL.createObjectURL(blob);link.download=filename;link.click();
      URL.revokeObjectURL(link.href);
      showToast('数据已导出: '+filename,'success');
    }

    function generateReport(){
      showReportModal('风险总览');
    }

    function showReportModal(panelName){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML='<div class="modal-content"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">生成报告</span></div><div class="modal-body"><p>正在为 "<strong>'+panelName+'</strong>" 生成分析报告...</p><div class="report-progress"><div class="progress-bar"><div class="progress-fill"></div></div></div><p class="report-status">正在提取数据...</p></div></div>';
      document.body.appendChild(modal);
      setTimeout(()=>{
        const progressFill=modal.querySelector('.progress-fill');
        const reportStatus=modal.querySelector('.report-status');
        let progress=0;
        const stages=['正在提取数据...','正在生成图表...','正在计算指标...','正在生成报告...','报告生成完成'];
        const interval=setInterval(()=>{
          progress+=20;
          progressFill.style.width=progress+'%';
          if(progress<=100)reportStatus.textContent=stages[Math.floor(progress/25)];
          if(progress>=100){clearInterval(interval);setTimeout(()=>{modal.querySelector('.modal-body').innerHTML='<div class="report-success"><span class="success-icon">✓</span><p>报告生成成功！</p><p class="report-filename">'+panelName+'_报告_'+new Date().toLocaleDateString()+'.pdf</p><button class="btn primary" onclick="this.closest(\'.modal-overlay\').remove()">确定</button></div>';},300);}
        },400);
      },100);
    }

    function showToast(message,type){
      const existing=document.querySelector('.toast-notification');
      if(existing)existing.remove();
      const toast=document.createElement('div');
      toast.className='toast-notification '+type;
      toast.innerHTML='<span>'+message+'</span>';
      document.body.appendChild(toast);
      setTimeout(()=>toast.classList.add('show'),10);
      setTimeout(()=>{toast.classList.remove('show');setTimeout(()=>toast.remove(),300);},3000);
    }

    function showAlertHistory(){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content" style="width:550px;"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">预警历史记录</span></div><div class="modal-body" style="padding:16px;"><div style="display:flex;gap:8px;margin-bottom:12px;"><button class="btn" onclick="filterAlertHistory('all')" style="font-size:11px;padding:4px 10px;">全部</button><button class="btn" onclick="filterAlertHistory('red')" style="font-size:11px;padding:4px 10px;">红色</button><button class="btn" onclick="filterAlertHistory('orange')" style="font-size:11px;padding:4px 10px;">橙色</button><button class="btn" onclick="filterAlertHistory('yellow')" style="font-size:11px;padding:4px 10px;">黄色</button></div><div class="alert-list" style="max-height:400px;overflow-y:auto;"><div class="alert-item alert-red" style="margin-bottom:8px;"><span class="alert-time">03/24 09:32</span><div class="alert-body"><strong>[红色]</strong> 国债收益率曲线倒挂加深</div></div><div class="alert-item alert-red" style="margin-bottom:8px;"><span class="alert-time">03/24 09:15</span><div class="alert-body"><strong>[红色]</strong> 信用债利差单日走阔22bp</div></div><div class="alert-item alert-yellow" style="margin-bottom:8px;"><span class="alert-time">03/24 08:58</span><div class="alert-body"><strong>[橙色]</strong> 离岸人民币汇率波动率异常</div></div><div class="alert-item alert-yellow" style="margin-bottom:8px;"><span class="alert-time">03/24 08:41</span><div class="alert-body"><strong>[橙色]</strong> SHIBOR隔夜利率上行</div></div><div class="alert-item alert-blue" style="margin-bottom:8px;"><span class="alert-time">03/24 08:30</span><div class="alert-body"><strong>[蓝色]</strong> 期权隐含波动率偏度异常</div></div><div class="alert-item alert-yellow" style="margin-bottom:8px;"><span class="alert-time">03/23 17:28</span><div class="alert-body"><strong>[橙色]</strong> 银行间市场流动性收紧</div></div><div class="alert-item alert-yellow" style="margin-bottom:8px;"><span class="alert-time">03/23 14:12</span><div class="alert-body"><strong>[橙色]</strong> 恒生指数下跌超过2%</div></div><div class="alert-item alert-red" style="margin-bottom:8px;"><span class="alert-time">03/23 10:05</span><div class="alert-body"><strong>[红色]</strong> 某信托公司评级下调</div></div></div><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;margin-top:12px;">关闭</button></div></div>`;
      document.body.appendChild(modal);
    }

    function showRiskDistribution(){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content" style="width:480px;"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">风险分布分析</span></div><div class="modal-body" style="padding:20px;"><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;"><div style="background:rgba(243,139,168,.1);padding:14px;border-radius:8px;text-align:center;"><div style="font-size:11px;color:var(--text-secondary);margin-bottom:6px;">高风险资产</div><div style="font-size:24px;font-family:'JetBrains Mono';color:var(--accent-red);font-weight:600">23.6%</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px;">占比</div></div><div style="background:rgba(249,226,175,.1);padding:14px;border-radius:8px;text-align:center;"><div style="font-size:11px;color:var(--text-secondary);margin-bottom:6px;">中等风险资产</div><div style="font-size:24px;font-family:'JetBrains Mono';color:var(--accent-yellow);font-weight:600">41.2%</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px;">占比</div></div><div style="background:rgba(166,227,161,.1);padding:14px;border-radius:8px;text-align:center;"><div style="font-size:11px;color:var(--text-secondary);margin-bottom:6px;">低风险资产</div><div style="font-size:24px;font-family:'JetBrains Mono';color:var(--accent-green);font-weight:600">35.2%</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px;">占比</div></div><div style="background:rgba(137,180,250,.1);padding:14px;border-radius:8px;text-align:center;"><div style="font-size:11px;color:var(--text-secondary);margin-bottom:6px;">风险集中度指数</div><div style="font-size:24px;font-family:'JetBrains Mono';color:var(--accent-blue);font-weight:600">0.67</div><div style="font-size:10px;color:var(--text-dim);margin-top:4px;">HHI指数</div></div></div><div style="background:rgba(255,255,255,.03);padding:12px;border-radius:8px;margin-bottom:12px;"><div style="font-size:12px;color:var(--text-primary);margin-bottom:8px;font-weight:500;">行业分布</div><div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:11px;"><span style="color:var(--text-secondary)">房地产</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">23.4%</span></div><div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:11px;"><span style="color:var(--text-secondary)">金融</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">18.7%</span></div><div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:11px;"><span style="color:var(--text-secondary)">城投</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">15.2%</span></div><div style="display:flex;justify-content:space-between;font-size:11px;"><span style="color:var(--text-secondary)">其他</span><span style="font-family:'JetBrains Mono';color:var(--text-primary)">42.7%</span></div></div><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;">确定</button></div></div>`;
      document.body.appendChild(modal);
    }

    function filterAlertHistory(level){
      showToast('已筛选'+{all:'全部',red:'红色',orange:'橙色',yellow:'黄色'}[level]+'预警','success');
    }

    document.querySelectorAll('.toggle-switch').forEach(function(sw){sw.addEventListener('click',function(){this.classList.toggle('active');});});

    function filterAlerts(level){
      const alerts = document.querySelectorAll('.alert-item');
      alerts.forEach(alert => {
        if(level === 'all'){
          alert.style.display = 'flex';
        } else if(level === 'red' && alert.classList.contains('alert-red')){
          alert.style.display = 'flex';
        } else if(level === 'orange' && alert.classList.contains('alert-yellow')){
          alert.style.display = 'flex';
        } else if(level !== 'all'){
          alert.style.display = 'none';
        }
      });
      document.querySelectorAll('.card-head .trend-btn').forEach(btn => {
        btn.classList.remove('active');
        if(btn.textContent === (level === 'all' ? '全部' : level === 'red' ? '红色' : '橙色')){
          btn.classList.add('active');
        }
      });
      showToast('已筛选'+{all:'全部',red:'红色',orange:'橙色'}[level]+'预警','success');
    }

    function acknowledgeAlert(btn){
      btn.textContent = '已确认';
      btn.style.background = 'rgba(166,227,161,.15)';
      btn.style.color = 'var(--accent-green)';
      btn.disabled = true;
      showToast('预警已确认','success');
    }

    function acknowledgeAllAlerts(){
      document.querySelectorAll('.alert-item .trend-btn').forEach(btn => {
        btn.textContent = '已确认';
        btn.style.background = 'rgba(166,227,161,.15)';
        btn.style.color = 'var(--accent-green)';
        btn.disabled = true;
      });
      showToast('已确认全部预警','success');
    }

    function sortInstitutions(criteria){
      const tbody = document.getElementById('institutionTableBody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        if(criteria === 'score'){
          return parseFloat(b.cells[1].textContent) - parseFloat(a.cells[1].textContent);
        } else {
          return a.cells[0].textContent.localeCompare(b.cells[0].textContent);
        }
      });
      rows.forEach(row => tbody.appendChild(row));
      document.querySelectorAll('.card-head .trend-btn').forEach(btn => {
        btn.classList.remove('active');
        if(btn.textContent.includes(criteria === 'score' ? '评分' : '名称')){
          btn.classList.add('active');
        }
      });
      showToast('已按'+{score:'评分',name:'名称'}[criteria]+'排序','success');
    }

    function removeInstitution(name){
      if(confirm('确定要从监测列表中移除 '+name+' 吗？')){
        showToast(name+' 已从监测列表移除','success');
      }
    }

    function addToWatchlist(){
      showToast('已添加到重点关注列表','success');
    }

    function exportInstitutionList(){
      let csv = '\uFEFF 机构名称，风险评分，等级\n';
      document.querySelectorAll('#institutionTableBody tr').forEach(row => {
        const cells = row.querySelectorAll('td');
        csv += cells[0].textContent + ',' + cells[1].textContent + ',' + cells[2].textContent + '\n';
      });
      const blob = new Blob([csv],{type:'text/csv;charset=utf-8;'});
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = 'institution_list.csv';
      link.click();
      showToast('机构清单已导出','success');
    }

    function showDashboardConfig(){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content" style="width:500px;"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">仪表盘配置</span></div><div class="modal-body" style="padding:20px;"><div style="background:rgba(255,255,255,.03);border-radius:8px;padding:12px;margin-bottom:12px;"><div style="font-size:12px;color:var(--text-primary);margin-bottom:8px;font-weight:500;">显示模块配置</div><label style="display:flex;align-items:center;margin-bottom:8px;cursor:pointer;"><input type="checkbox" checked style="margin-right:8px;">综合风险指数</label><label style="display:flex;align-items:center;margin-bottom:8px;cursor:pointer;"><input type="checkbox" checked style="margin-right:8px;">风险等级分布</label><label style="display:flex;align-items:center;margin-bottom:8px;cursor:pointer;"><input type="checkbox" checked style="margin-right:8px;">实时预警信息</label><label style="display:flex;align-items:center;margin-bottom:8px;cursor:pointer;"><input type="checkbox" checked style="margin-right:8px;">重点监测机构</label></div><div style="display:flex;gap:8px;"><button class="btn" onclick="this.closest('.modal-overlay').remove()" style="flex:1;">取消</button><button class="btn primary" onclick="saveDashboardConfig()" style="flex:1;">保存配置</button></div></div></div>`;
      document.body.appendChild(modal);
    }

    function saveDashboardConfig(){
      showToast('仪表盘配置已保存','success');
    }

    function compareRiskPeriods(){
      const modal=document.createElement('div');
      modal.className='modal-overlay';
      modal.innerHTML=`<div class="modal-content" style="width:550px;"><div class="modal-header"><div class="traffic-lights"><div class="traffic-light close" onclick="this.closest('.modal-overlay').remove()"></div><div class="traffic-light minimize"></div><div class="traffic-light maximize"></div></div><span class="modal-title">风险指标对比分析</span></div><div class="modal-body" style="padding:16px;"><table class="data-table" style="margin-bottom:12px;"><thead><tr><th>指标</th><th>本期</th><th>上期</th><th>变化</th></tr></thead><tbody><tr><td class="name-col">综合风险指数</td><td style="color:var(--accent-yellow)">67.4</td><td style="color:var(--accent-blue)">64.2</td><td style="color:var(--accent-red)">+3.2</td></tr><tr><td class="name-col">VaR(99%,1D)</td><td style="color:var(--accent-mauve)">2.34%</td><td style="color:var(--accent-blue)">2.16%</td><td style="color:var(--accent-red)">+0.18%</td></tr><tr><td class="name-col">预警数量</td><td style="color:var(--accent-red)">18</td><td style="color:var(--accent-yellow)">13</td><td style="color:var(--accent-red)">+5</td></tr></tbody></table><button class="btn primary" onclick="this.closest('.modal-overlay').remove()" style="width:100%;">确定</button></div></div>`;
      document.body.appendChild(modal);
    }
  </script>
</body>
</html>
